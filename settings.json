      "WebFetch(domain:mcp.sentry.dev)",
      "WebFetch(domain:mise-versions.jdx.dev)",
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:motlin.com)",
      "WebFetch(domain:mvnrepository.com)",
      "WebFetch(domain:oclif.io)",
