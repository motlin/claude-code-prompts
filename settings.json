{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 99999,
  "env": {
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Search",
      "WebSearch",
      "Write",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(osascript:*)",
      "Bash(pmset:*)",
      "Bash(python3:*)",
      "Bash(rm:*)",
      "Bash(sqlite3:*)",
      "Bash(wrangler:*)",
      "Skill(example-skills:*)",
      "Skill(plugin-dev:skill-development)",
      "WebFetch(domain:adoptium.net)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:avalon.onl)",
      "WebFetch(domain:beta.workflowy.com)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:blog.cloudflare.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:community.hetzner.com)",
      "WebFetch(domain:community.render.com)",
      "WebFetch(domain:dash.cloudflare.com)",
      "WebFetch(domain:developer.1password.com)",
      "WebFetch(domain:developer.jboss.org)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:docs.datasette.io)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.hetzner.com)",
      "WebFetch(domain:docs.render.com)",
      "WebFetch(domain:docs.rwsdk.com)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:docusaurus.io)",
      "WebFetch(domain:domains.cloudflare.com)",
      "WebFetch(domain:formulae.brew.sh)",
      "WebFetch(domain:giscus.app)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:issues.apache.org)",
      "WebFetch(domain:iterm2.com)",
      "WebFetch(domain:junit-pioneer.org)",
      "WebFetch(domain:liftwizard.io)",
      "WebFetch(domain:mavenplugins.github.io)",
      "WebFetch(domain:mcp.sentry.dev)",
      "WebFetch(domain:oclif.io)",
      "WebFetch(domain:orm.drizzle.team)",
      "WebFetch(domain:patch-diff.githubusercontent.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:prettier.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:render.com)",
      "WebFetch(domain:sentry.io)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:taskwarrior.org)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:workflowy.com)",
      "WebFetch(domain:www.apache.org)",
      "WebFetch(domain:www.dropwizard.io)",
      "WebFetch(domain:www.eclipse.org)",
      "WebFetch(domain:www.hetzner.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:www.prisma.io)",
      "mcp__chrome-devtools__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_serena_serena__*",
      "mcp__render__*",
      "mcp__sentry__*",
      "mcp__serena__*"
    ],
    "deny": [
      "Bash(npm i --global:*)",
      "Bash(npm i -g:*)",
      "Bash(npm install --global:*)",
      "Bash(npm install -g:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run serve:*)",
      "Bash(npm run start &)",
      "Bash(npm run start:*)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.zprofile)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)"
    ],
    "ask": [
      "Edit(CLAUDE.md)",
      "Edit(~/.claude/settings.json)",
      "Write(CLAUDE.md)",
      "Bash(op)",
      "Bash(op:*)",
      "Bash(open:*)",
      "Bash(trash:*)",
      "Bash(/opt/homebrew/bin/gh:*)",
      "Bash(gh api*repos*/pulls:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command'); if echo \"$CMD\" | grep -qE 'rm[[:space:]]+-[^[:space:]]*r[^[:space:]]*f'; then echo 'BLOCKED: Use trash instead of rm -rf' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command'); if echo \"$CMD\" | grep -qE 'git[[:space:]]+push.*(main|master)'; then echo 'BLOCKED: Use feature branches, not direct push to main' >&2; exit 2; fi"
          },
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command'); if echo \"$CMD\" | grep -qE 'git[[:space:]]+push.*--force' && ! echo \"$CMD\" | grep -qE '\\-\\-force-with-lease'; then echo 'BLOCKED: Use --force-with-lease instead of --force' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (now | todate) + \"] \" + .tool_input.command' >> ~/.claude/bash-commands.log"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "build@motlin-claude-code-plugins": true,
    "builtin-tasks@motlin-claude-code-plugins": true,
    "code@motlin-claude-code-plugins": true,
    "git@motlin-claude-code-plugins": true,
    "github@motlin-claude-code-plugins": true,
    "iterm2-titles@motlin-claude-code-plugins": true,
    "java@motlin-claude-code-plugins": true,
    "justfile@motlin-claude-code-plugins": true,
    "markdown-tasks@motlin-claude-code-plugins": true,
    "offline-claude-code-guide@motlin-claude-code-plugins": true,
    "orchestration@motlin-claude-code-plugins": true,
    "pushover@motlin-claude-code-plugins": true,
    "tmux-titles@motlin-claude-code-plugins": true,
    "humanizer@skills-curated": true,
    "skill-extractor@skills-curated": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "openai-gh-address-comments@skills-curated": true,
    "openai-playwright@skills-curated": true,
    "openai-screenshot@skills-curated": true
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux"
}
