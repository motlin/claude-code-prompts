      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.datasette.io)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.hetzner.com)",
      "WebFetch(domain:docs.openrewrite.org)",
      "WebFetch(domain:docs.render.com)",
      "WebFetch(domain:docs.rwsdk.com)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:docusaurus.io)",
      "WebFetch(domain:domains.cloudflare.com)",
