{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Search",
      "WebSearch",
      "Write",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(claude mcp --help)",
      "Bash(claude mcp get *)",
      "Bash(claude mcp list)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(npm show *)",
      "Bash(npm:*)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx:*)",
      "Bash(osascript:*)",
      "Bash(pmset:*)",
      "Bash(pnpm ls *)",
      "Bash(python3:*)",
      "Bash(rm:*)",
      "Bash(sqlite3:*)",
      "Bash(wrangler:*)",
      "Skill(code-review:*)",
      "Skill(example-skills:*)",
      "Skill(hookify:hookify)",
      "Skill(humanizer)",
      "Skill(plugin-dev:*)",
      "WebFetch(domain:adoptium.net)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:avalon.onl)",
      "WebFetch(domain:beta.workflowy.com)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:blog.cloudflare.com)",
      "WebFetch(domain:central.sonatype.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:community.hetzner.com)",
      "WebFetch(domain:community.render.com)",
      "WebFetch(domain:dash.cloudflare.com)",
      "WebFetch(domain:developer.1password.com)",
      "WebFetch(domain:developer.jboss.org)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.datasette.io)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.hetzner.com)",
      "WebFetch(domain:docs.openrewrite.org)",
      "WebFetch(domain:docs.render.com)",
      "WebFetch(domain:docs.rwsdk.com)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:docusaurus.io)",
      "WebFetch(domain:domains.cloudflare.com)",
      "WebFetch(domain:eclipse.dev)",
      "WebFetch(domain:errorprone.info)",
      "WebFetch(domain:formulae.brew.sh)",
      "WebFetch(domain:ghostty.org)",
      "WebFetch(domain:giscus.app)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:issues.apache.org)",
      "WebFetch(domain:iterm2.com)",
      "WebFetch(domain:junit-pioneer.org)",
      "WebFetch(domain:just.systems)",
      "WebFetch(domain:liftwizard.io)",
      "WebFetch(domain:mavenplugins.github.io)",
      "WebFetch(domain:mcp.sentry.dev)",
      "WebFetch(domain:mise-versions.jdx.dev)",
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:motlin.com)",
      "WebFetch(domain:mvnrepository.com)",
      "WebFetch(domain:oclif.io)",
      "WebFetch(domain:orm.drizzle.team)",
      "WebFetch(domain:patch-diff.githubusercontent.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:plugins.jetbrains.com)",
      "WebFetch(domain:prettier.io)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:render.com)",
      "WebFetch(domain:repo1.maven.org)",
      "WebFetch(domain:sentry.io)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:storybook.js.org)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:taskwarrior.org)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:web.archive.org)",
      "WebFetch(domain:workflowy.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:www.apache.org)",
      "WebFetch(domain:www.dropwizard.io)",
      "WebFetch(domain:www.eclipse.org)",
      "WebFetch(domain:www.hetzner.com)",
      "WebFetch(domain:www.javadoc.io)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:www.prisma.io)",
      "mcp__agent-browser__*",
      "mcp__chrome-devtools__*",
      "mcp__claude_ai_Gmail__get_thread",
      "mcp__claude_ai_Gmail__gmail_get_profile",
      "mcp__claude_ai_Gmail__gmail_read_message",
      "mcp__claude_ai_Gmail__gmail_read_thread",
      "mcp__claude_ai_Gmail__gmail_search_messages",
      "mcp__claude_ai_Gmail__search_threads",
      "mcp__claude_ai_Google_Calendar__create_event",
      "mcp__claude_ai_Google_Calendar__gcal_create_event",
      "mcp__claude_ai_Google_Calendar__gcal_list_events",
      "mcp__claude_ai_Google_Calendar__list_calendars",
      "mcp__claude_ai_Google_Calendar__list_events",
      "mcp__gmail__read_email",
      "mcp__gmail__search_emails",
      "mcp__imcp__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_playwright_playwright__*"
    ],
    "deny": [
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(npm i --global:*)",
      "Bash(npm i -g:*)",
      "Bash(npm install --global:*)",
      "Bash(npm install -g:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)"
    ],
    "ask": [
      "Bash(/opt/homebrew/bin/gh:*)",
      "Bash(gh api*repos*/pulls:*)",
      "Bash(op:*)",
      "Bash(open:*)",
      "Bash(sudo:*)",
      "Bash(trash -fr:*)",
      "Bash(trash -r:*)",
      "Bash(trash -rf:*)",
      "Edit(CLAUDE.md)",
      "Edit(~/.bashrc)",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.zprofile)",
      "Edit(~/.zshrc)",
      "Read(~/.ssh/**)",
      "Write(CLAUDE.md)"
    ],
    "defaultMode": "plan"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "claude-reflect@claude-reflect-marketplace": true,
    "markdown-tasks@motlin-claude-code-plugins": true,
    "build@motlin-claude-code-plugins": true,
    "builtin-tasks@motlin-claude-code-plugins": true,
    "code@motlin-claude-code-plugins": true,
    "ghostty-titles@motlin-claude-code-plugins": true,
    "git@motlin-claude-code-plugins": true,
    "github@motlin-claude-code-plugins": true,
    "iterm2-titles@motlin-claude-code-plugins": true,
    "java@motlin-claude-code-plugins": true,
    "justfile@motlin-claude-code-plugins": true,
    "offline-claude-code-guide@motlin-claude-code-plugins": true,
    "orchestration@motlin-claude-code-plugins": true,
    "tmux-titles@motlin-claude-code-plugins": true,
    "worktree-setup@motlin-claude-code-plugins": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "remember@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "humanizer@skills-curated": true,
    "skill-extractor@skills-curated": true,
    "context7@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "imessage@claude-plugins-official": true,
    "pushover@motlin-claude-code-plugins": true,
    "telegram@claude-plugins-official": true,
    "claude-code-plans@motlin-claude-code-plugins": true,
    "git-guards@motlin-claude-code-plugins": true,
    "plugin-and-skill-dev@motlin-claude-code-plugins": true,
    "temporal-data@motlin-claude-code-plugins": true,
    "stop-phrase-guard@motlin-claude-code-plugins": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "bash-audit-log@motlin-claude-code-plugins": true,
    "bash-guards@motlin-claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "claude-reflect-marketplace": {
      "source": {
        "source": "github",
        "repo": "bayramannakov/claude-reflect"
      }
    },
    "motlin-claude-code-plugins": {
      "source": {
        "source": "directory",
        "path": "/Users/craig/projects/claude-code-plugins"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "skills-curated": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills-curated"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "fileCheckpointingEnabled": false,
  "teammateMode": "in-process",
  "voiceEnabled": true
}
